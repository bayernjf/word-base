{
  "expo": {
    "name": "WordBase",
    "slug": "word-base",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.wordbase.mobile",
      "supportsTablet": true
    },
    "android": {
      "package": "com.wordbase.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      ["expo-clipboard"],
      ["expo-speech"],
      ["expo-notifications"]
    ]
  }
}