{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WordBase",
  "version": "0.0.0",
  "identifier": "com.wordbase.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3002",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WordBase",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https: wss:; img-src 'self' data: https: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data: https:; media-src 'self' https: blob:;"
    },
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": true,
      "tooltip": "WordBase"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Education",
    "shortDescription": "WordBase - AI-powered vocabulary learning",
    "longDescription": "WordBase 是一款基于 AI 的英语单词学习与复习工具，支持 SRS 间隔重复、AI 释义、多端同步。",
    "copyright": "Copyright © 2026 WordBase"
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
