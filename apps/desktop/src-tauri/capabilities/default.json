{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "WordBase 桌面端默认能力集：剪贴板、通知、TTS（仅限 say / powershell SAPI Speech）、持久化 KV。",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",

    "clipboard-manager:default",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text",

    "notification:default",
    "notification:allow-notify",
    "notification:allow-is-permission-granted",
    "notification:allow-request-permission",

    "store:default",
    "store:allow-load",
    "store:allow-get",
    "store:allow-set",
    "store:allow-delete",
    "store:allow-keys",
    "store:allow-save",

    "shell:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "say",
          "cmd": "say",
          "args": true,
          "sidecar": false
        },
        {
          "name": "powershell-tts",
          "cmd": "powershell",
          "args": [
            { "validator": "eq", "arg": "-Command" },
            { "validator": "regex", "arg": "^Add-Type -AssemblyName System\\.Speech;\\s*\\$s\\s*=\\s*New-Object System\\.Speech\\.Synthesis\\.SpeechSynthesizer;\\s*\\$s\\.Speak\\('.*'\\)\\s*$" }
          ],
          "sidecar": false
        }
      ]
    }
  ]
}
