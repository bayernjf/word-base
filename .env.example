# =============================================
# WordBase 环境变量模板
# 复制此文件为 .env（根目录）并填入真实值
# 另外还需要 apps/web/.env.local 和 packages/api/.env
# =============================================

# =============================================
# Supabase 配置（必填）
# - NEXT_PUBLIC_ 开头的变量会暴露给 Web 前端（浏览器可见）
# - VITE_ 开头的变量会暴露给 Desktop/Mobile 客户端
# - SUPABASE_SERVICE_ROLE_KEY 仅后端使用，绝不能暴露给前端
# =============================================
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-public-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# =============================================
# 数据分析（可选，生产环境使用）
# Google Analytics 4 + Microsoft Clarity 免费组合
# 不配置则不会加载任何分析脚本
# =============================================
VITE_GA_MEASUREMENT_ID=""
VITE_CLARITY_PROJECT_ID=""

# =============================================
# AI 配置加密密钥（必填）
# 用于加密用户在前端配置的 AI Provider API Key
# 生成方式：openssl rand -base64 32
# =============================================
AI_CONFIG_ENCRYPTION_KEY="replace-with-a-32-byte-random-base64-string"

# =============================================
# API 后端服务端口
# =============================================
PORT=3001
NODE_ENV=development

# =============================================
# API 后端地址（各端独立配置）
# 运行时由 shared/lib/apiBase.ts 自动选择
# 优先级：NEXT_PUBLIC_API_BASE_URL > 各端专用变量
# =============================================

# 通用覆盖（优先级最高，临时调试时改这个）
# NEXT_PUBLIC_API_BASE_URL=""

# Web 端本地开发（Next.js dev server 直连 API）
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001"

# Desktop (Tauri) — Mac/Win 本地开发走 localhost
VITE_DESKTOP_API_BASE_URL="http://localhost:3001"

# iOS 模拟器 — localhost
VITE_IOS_API_BASE_URL="http://localhost:3001"

# Android 模拟器 — AVD 专用地址 10.0.2.2 指向宿主机 localhost
VITE_ANDROID_API_BASE_URL="http://10.0.2.2:3001"

# 真机调试（手机和电脑连同一 WiFi，填电脑内网 IP）
# VITE_IOS_API_BASE_URL="http://192.168.x.x:3001"
# VITE_ANDROID_API_BASE_URL="http://192.168.x.x:3001"

# =============================================
# 同步服务地址（可选，留空则使用 API_BASE_URL）
# =============================================
# NEXT_PUBLIC_SYNC_SERVER_URL=""
